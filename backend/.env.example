# Required - Your fallback OpenAI API key (used when user hasn't set their own)
OPENAI_API_KEY=sk-your-openai-api-key

# Supabase - Get these from your Supabase project dashboard
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
SUPABASE_URL=https://[PROJECT_REF].supabase.co

# Legacy JWT secret (optional - only needed if you haven't migrated to new JWT Signing Keys)
# The backend auto-discovers the public key from SUPABASE_URL via JWKS for ES256/RS256 keys.
# You can get this from: Supabase Dashboard > Settings > JWT Keys > Legacy JWT Secret > Reveal
SUPABASE_JWT_SECRET=

# Encryption key for OpenAI API keys at rest (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=

# Optional
PORT=8000
